{
  "$schema": "https://pg-language-server.com/latest/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "typecheck": {
    "enabled": true
  },
  "plpgsqlCheck": {
    "enabled" : true
  },
  "db": {
    "connectionString": "postgres://postgres:postgres@localhost:5432/urlspace?sslmode=disable",
    "allowStatementExecutionsAgainst": ["127.0.0.1/*", "localhost/*"]
  }
}
